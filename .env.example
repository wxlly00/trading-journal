# ═══════════════════════════════════════════════════════════════
#  Trading Journal — Variables d'environnement
#  Copie ce fichier en ".env" et remplis tes valeurs.
# ═══════════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────────
# Crée un projet gratuit sur https://supabase.com
# Dashboard → Settings → API

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # Service Role (secret !)

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...      # Anon Key (public)

# ── CORS backend ────────────────────────────────────────────────
# URL depuis laquelle le navigateur appelle l'API
CORS_ORIGINS=http://localhost

# ── Optionnel ───────────────────────────────────────────────────
RESEND_API_KEY=
